# ════════════════════════════════════════════════════════════════
# NEXUS PLATFORM - PRODUCTION ENVIRONMENT
# ════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ─── DATABASE ──────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── SECRETS (generate with: openssl rand -hex 32) ─────────────
SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32_DIFFERENT

# ─── EMAIL ─────────────────────────────────────────────────────
# For Gmail: Enable 2FA and create an App Password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# For Mailgun (free tier available):
# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@mg.yourdomain.com
# MAIL_PASSWORD=your-mailgun-smtp-password

# ─── APP ───────────────────────────────────────────────────────
APP_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
VITE_API_URL=https://yourdomain.com/api

# ─── ADMIN ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
ADMIN_USERNAME=admin
